{
  "compilerOptions": {
    "checkJs": true
  },

  "exclude": [
    "eslint.config.js",
    "node_modules",
    "test/captions",
    "test/identify",
    "test/should-fail",
    "**/vendor/**",
  ],
  "imports": {
    // dormant in av repo - add via `npm add puppeteer` if needed in prod
    // (these are just for `deno check` in `lint` ..
    "puppeteer": "data:application/javascript,export default {}",
    "@playwright/test": "data:application/javascript,export default {}",
  },


  "lint": {
    "exclude": [
      "node_modules",
      "vendor",
      "web_modules",
      "**/*.min.js",

      "__JWPLAYER-STUFF__",
      "www/jw/",
      "www/jw/head/",
      "www/jw/8/",
      "www/jw/8.2.3/",
      "www/jw/8.8.2/",
      "jwplayer.controls.js",
      "jwplayer.core.js",
      "jwplayer.core.*",
      "polyfills.webvtt.js",
      "vttparser.js",

      "__AV_STUFF__",
      "www/cast/www.gstatic.com/",
      "**/lib/binsearch/",
      "**/lib/extracTS/",
      "**/lib/ffmpeg/",
      "test/captions",
      "test/identify",

      "__PETABOX_STUFF__",
      "**/components/bookreader/",
      "**/components/npm/",
      "**/components/editxml/jquery.json-ui.js",
      "**/components/uploader/jquery.sprintf.js",
      "**/components/uploader/jquery.wysiwyg.js",
      "**/components/uploader/wysiwyg.link.js",

      "__MISC_STUFF__",
      "**/eveal.js",
      "**/reveal.js/**",
    ],
    "rules": {
      "tags": ["recommended"],
      "exclude": [
        "camelcase"
      ]
    }
  }
}
